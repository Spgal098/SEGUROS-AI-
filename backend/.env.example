# TextilIA Seguros — variables de entorno (nombres; NUNCA subir .env real)
# Credenciales TOTALMENTE independientes de TextilIA Textiles.

NODE_ENV=development
PORT=3002
CORS_ALLOWED_ORIGIN=http://localhost:5174

# Supabase — proyecto PROPIO de Seguros (no reutilizar el de Textiles)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SOLO backend — jamás en frontend:
SUPABASE_SERVICE_ROLE_KEY=

# Rol de backend SIN BYPASSRLS (endurecimiento Fase 6).
# 1) npm run role:create  → crea el rol app_backend (NOLOGIN, sin bypass)
# 2) define una contraseña aquí y ejecuta: npm run role:activate
APP_BACKEND_PASSWORD=
# 3) cadena de conexión con el rol app_backend (misma DB, usuario app_backend).
#    Cuando esté presente, el backend la usa en vez de DATABASE_URL.
APP_BACKEND_DATABASE_URL=

# Auth (Fase 3)
AUTH_ENABLED=false
AUTH_PROVIDER=supabase

# IA comercial
AI_ENABLED=false
OPENAI_API_KEY=

# WhatsApp Business (Fase 5) — número y cuenta propios de Seguros
WHATSAPP_ENABLED=false
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v19.0

# Operación
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
